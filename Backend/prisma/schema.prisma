generator client {
  provider = "prisma-client"
  output   = "../generated/prisma" // or wherever
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  master
}

enum AppointmentStatus {
  Завершен
  Подтвержден
  Новый
  Отменен
}

enum TimeOffType {
  vacation // Отпуск
  sick_leave // Больничный
  day_off // Отгул/выходной по приказу
  other // Другое
}

// done
model User {
  id         Int      @id @default(autoincrement())
  name       String?
  login      String   @unique
  password   String
  profileImg String?  @map("profile_img")
  role       Role
  master     Master?  @relation(fields: [masterId], references: [id])
  masterId   Int?     @map("master_id")
  isActive   Boolean? @default(true) @map("is_active")

  @@map("user")
}

// done
model Master {
  id              Int              @id @default(autoincrement())
  surname         String
  name            String
  middlename      String           @map("middle_name")
  specialization  String
  phone           String           @unique
  isActive        Boolean          @default(true) @map("is_active")
  photo           String?
  servicePrices   ServicePrice[]
  appointments    Appointment[]
  masterSchedules MasterSchedule[]
  users           User[]
  masterTimeOffs  MasterTimeOff[]

  @@map("master")
}

//done
model MasterSchedule {
  id        Int      @id @default(autoincrement())
  master    Master   @relation(fields: [masterID], references: [id], onDelete: Cascade)
  masterID  Int      @map("master_id")
  dayOfWeek Int?     @map("day_of_week") // ← изменено: Int → Int?
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")

  @@index([masterID])
  @@index([masterID, dayOfWeek])
  @@index([startTime, endTime])
  @@map("master_schedule")
}

model MasterTimeOff {
  id       Int    @id @default(autoincrement())
  master   Master @relation(fields: [masterId], references: [id], onDelete: Cascade)
  masterId Int    @map("master_id")

  startDate DateTime @map("start_date") // 2026-04-01 00:00:00
  endDate   DateTime @map("end_date") // 2026-04-14 23:59:59

  type    TimeOffType @default(vacation)
  comment String? // Необязательно: "Еду на море", "Больничный лист №123"

  createdAt DateTime @default(now()) @map("created_at")

  @@index([masterId, startDate, endDate])
  @@index([masterId, type])
  @@map("master_time_off")
}

// done
model Category {
  id          Int       @id @default(autoincrement())
  title       String    @unique
  description String
  isActive    Boolean   @default(true) @map("is_active")
  services    Service[]

  @@map("category")
}

// done
model Service {
  id            Int            @id @default(autoincrement())
  title         String
  description   String
  duration      Int
  img           String?
  isActive      Boolean        @default(true) @map("is_active")
  category      Category       @relation(fields: [categoryId], references: [id])
  categoryId    Int            @map("category_id")
  servicePrices ServicePrice[]
  appointments  Appointment[]

  @@map("service")
}

//done
model ServicePrice {
  id        Int     @id @default(autoincrement())
  service   Service @relation(fields: [serviceId], references: [id])
  serviceId Int     @map("service_id")
  master    Master  @relation(fields: [masterID], references: [id])
  masterID  Int     @map("master_id")
  price     Decimal @db.Decimal(10, 2)
  isActive  Boolean @default(true) @map("is_active")

  durationOverride Int? @map("duration_override")

  @@map("service_price")
}

//done
model Appointment {
  id              Int               @id @default(autoincrement())
  clientSurname   String            @map("client_surname")
  clientName      String            @map("client_name")
  clientPhone     String            @map("client_phone")
  master          Master            @relation(fields: [masterID], references: [id])
  masterID        Int               @map("master_id")
  service         Service           @relation(fields: [serviceId], references: [id])
  serviceId       Int               @map("service_id")
  appointmentTime DateTime          @map("appointment_time")
  price           Decimal           @db.Decimal(10, 2)
  status          AppointmentStatus @default(Новый)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@unique([masterID, appointmentTime])
  @@map("appointment")
}

//done
model AppointmentHistory {
  id              Int      @id @default(autoincrement())
  appointmentId   Int
  clientSurname   String
  clientName      String
  clientPhone     String
  masterID        Int
  serviceId       Int
  appointmentTime DateTime
  price           Decimal  @db.Decimal(10, 2)
  completedAt     DateTime @default(now())

  @@map("appointment_history")
}
